{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Update",
      "Edit",
      "Glob",
      "Grep",
      "Skill",
      "WebSearch",
      "WebFetch",
      "mcp__dev-tools__list_files",
      "mcp__dev-tools__create_directory",
      "mcp__dev-tools__remove",
      "mcp__dev-tools__remove_recursive",
      "mcp__dev-tools__copy",
      "mcp__dev-tools__move",
      "mcp__dev-tools__parse_syntax_tree",
      "mcp__dev-tools__dotnet_build",
      "mcp__dev-tools__dotnet_test",
      "mcp__dev-tools__dotnet_restore",
      "mcp__git__git_status",
      "mcp__git__git_add",
      "mcp__git__git_commit",
      "mcp__git__git_diff",
      "mcp__git__git_log",
      "mcp__git__git_show",
      "mcp__git__git_blame",
      "mcp__git__git_branch",
      "mcp__git__git_checkout",
      "mcp__git__git_merge",
      "mcp__git__git_rebase",
      "mcp__git__git_cherry_pick",
      "mcp__git__git_fetch",
      "mcp__git__git_pull",
      "mcp__git__git_push",
      "mcp__git__git_remote",
      "mcp__git__git_tag",
      "mcp__git__git_stash",
      "mcp__git__git_reset",
      "mcp__git__git_clean",
      "mcp__git__git_reflog",
      "mcp__git__git_worktree",
      "mcp__git__git_set_working_dir",
      "mcp__dotnet__dotnet_project",
      "mcp__dotnet__dotnet_package",
      "mcp__dotnet__dotnet_solution",
      "mcp__dotnet__dotnet_sdk",
      "mcp__sherlock__get_project_output_paths",
      "mcp__sherlock__get_type_fields",
      "mcp__sherlock__get_type_methods",
      "mcp__sherlock__get_type_properties",
      "mcp__sherlock__get_type_constructors",
      "mcp__sherlock__get_type_info",
      "mcp__sherlock__get_all_type_members",
      "mcp__sherlock__get_type_hierarchy",
      "mcp__sherlock__get_xml_docs_for_type",
      "mcp__sherlock__find_assembly_by_class_name",
      "mcp__sherlock__find_assembly_by_file_name",
      "mcp__sherlock__analyze_type",
      "mcp__sherlock__analyze_project",
      "mcp__sherlock__get_types_from_assembly",
      "mcp__microsoft-learn__microsoft_docs_fetch",
      "mcp__microsoft-learn__microsoft_docs_search",
      "mcp__jetbrains__build_project",
      "mcp__jetbrains__create_new_file",
      "mcp__jetbrains__execute_run_configuration",
      "mcp__jetbrains__find_files_by_glob",
      "mcp__jetbrains__find_files_by_name_keyword",
      "mcp__jetbrains__get_all_open_file_paths",
      "mcp__jetbrains__get_file_problems",
      "mcp__jetbrains__get_file_text_by_path",
      "mcp__jetbrains__get_project_dependencies",
      "mcp__jetbrains__get_project_modules",
      "mcp__jetbrains__get_repositories",
      "mcp__jetbrains__get_run_configurations",
      "mcp__jetbrains__get_symbol_info",
      "mcp__jetbrains__list_directory_tree",
      "mcp__jetbrains__open_file_in_editor",
      "mcp__jetbrains__reformat_file",
      "mcp__jetbrains__rename_refactoring",
      "mcp__jetbrains__replace_text_in_file",
      "mcp__jetbrains__search_in_files_by_regex",
      "mcp__jetbrains__search_in_files_by_text"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/save-session-metadata.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [[ \"$FILE\" == *.cs ]]; then dotnet format --include \"$FILE\" 2>/dev/null; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__jetbrains__execute_terminal_command",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Bash|Terminal were manually disabled by Houtamelo. You should have all the MCP tools you need to perform your job. If you believe your tools are lacking, tell Houtamelo and he will add to and/or improve your tooling.' >&2; exit 2"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "analyzer-implementer|test-writer|test-case-writer|researcher|history-keeper",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/capture-session.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-task-tests.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/capture-session.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true
  },
  "enabledMcpjsonServers": [
    "sherlock",
    "dev-tools",
    "git",
    "dotnet"
  ]
}
