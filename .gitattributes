# Normalize all text files to LF
* text=auto eol=lf

# Ensure these are always treated as text
*.cs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.nupkg binary
*.dll binary
