{
  "mcpServers": {
    "sherlock": {
      "type": "stdio",
      "command": "sherlock-mcp",
      "env": {
        "DOTNET_ROOT": "/usr/lib/dotnet"
      }
    },
    "dev-tools": {
      "type": "stdio",
      "command": "dotnet",
      "args": ["run", "--project", "tools/DevTools"]
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "."]
    },
    "dotnet": {
      "type": "stdio",
      "command": "dnx",
      "args": ["Community.Mcp.DotNet@1.*", "--yes"]
    }
  }
}
