{
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "sherlock": {
      "type": "stdio",
      "command": "sherlock-mcp",
      "env": {
        "DOTNET_ROOT": "/usr/lib/dotnet"
      }
    },
    "dev-tools": {
      "type": "stdio",
      "command": "dotnet",
      "args": ["run", "--project", "tools/DevTools"]
    }
  }
}
